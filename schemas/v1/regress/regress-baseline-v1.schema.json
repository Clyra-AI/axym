{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axym.dev/schemas/v1/regress/regress-baseline-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "frameworks"],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "frameworks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["framework_id", "coverage", "controls"],
        "properties": {
          "framework_id": {
            "type": "string",
            "minLength": 1
          },
          "coverage": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "controls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["control_id", "status"],
              "properties": {
                "control_id": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": ["covered", "partial", "gap"]
                },
                "reason_codes": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "uniqueItems": true
                }
              }
            }
          }
        }
      }
    }
  }
}

