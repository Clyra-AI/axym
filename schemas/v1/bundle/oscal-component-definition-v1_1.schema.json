{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "component-definition"
  ],
  "properties": {
    "component-definition": {
      "type": "object",
      "required": [
        "uuid",
        "metadata",
        "components"
      ],
      "properties": {
        "uuid": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "required": [
            "title",
            "version",
            "last-modified"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "last-modified": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "uuid",
              "type",
              "title",
              "control-implementations"
            ],
            "properties": {
              "uuid": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "control-implementations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "source",
                    "implemented-requirements"
                  ],
                  "properties": {
                    "source": {
                      "type": "string",
                      "minLength": 1
                    },
                    "description": {
                      "type": "string"
                    },
                    "implemented-requirements": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "control-id",
                          "description"
                        ],
                        "properties": {
                          "control-id": {
                            "type": "string",
                            "minLength": 1
                          },
                          "description": {
                            "type": "string",
                            "minLength": 1
                          }
                        },
                        "additionalProperties": true
                      }
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
